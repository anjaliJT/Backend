{
  "info": {
    "name": "TeamBoard API",
    "description": "Postman collection for TeamBoard API testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"password\": \"secretpassword123\",\n  \"email\": \"johndoe@example.com\",\n  \"company_name\": \"Acme Corp\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register",
                ""
              ]
            },
            "description": "Registers a new user and creates their associated company. Returns access token."
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"password\": \"secretpassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login",
                ""
              ]
            },
            "description": "Logs in an existing user and returns an access token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Knowledge Base",
      "item": [
        {
          "name": "Query KB",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"search\": \"api\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/kb/query/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "kb",
                "query",
                ""
              ]
            },
            "description": "Search the Knowledge Base for entries containing the keyword in the question or answer."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Usage Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/usage-summary/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "usage-summary",
                ""
              ]
            },
            "description": "Get overall usage statistics. Requires Admin privileges."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "access_token",
      "value": "YOUR_JWT_ACCESS_TOKEN_HERE",
      "type": "string"
    }
  ]
}
